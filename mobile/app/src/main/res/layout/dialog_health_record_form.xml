<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pig"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/spinnerPig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weight (kg)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputHealthWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Temperature (C)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputHealthTemp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Condition"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputHealthCondition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Treatment Given"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputHealthTreatment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Medication Used"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputHealthMedication"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Next Treatment Date (YYYY-MM-DD)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputHealthNextDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Next Treatment Type"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputHealthNextType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checkup Date (YYYY-MM-DDTHH:MM)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputHealthCheckup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notes"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputHealthNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:textColor="@color/text_primary" />
    </LinearLayout>
</ScrollView>
