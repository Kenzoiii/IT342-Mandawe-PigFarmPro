<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pig"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/spinnerSalePig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Buyer Name"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputSaleBuyer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Buyer Contact"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputSaleContact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sale Price"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputSalePrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sale Date (YYYY-MM-DD)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputSaleDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Expected Pickup (YYYY-MM-DD)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputSaleExpected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Actual Pickup (YYYY-MM-DD)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputSaleActual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputSaleStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Payment Status"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputSalePayment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notes"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputSaleNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:textColor="@color/text_primary" />
    </LinearLayout>
</ScrollView>
