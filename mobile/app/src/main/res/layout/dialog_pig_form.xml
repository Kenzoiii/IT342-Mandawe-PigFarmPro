<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pig Identifier"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/inputPigIdentifier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Breed"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputPigBreed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gender"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputPigGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Birthdate (YYYY-MM-DD)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputPigBirthdate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weight"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputPigWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weight Unit"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputPigWeightUnit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:text="kg" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputPigStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:text="Active" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notes"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputPigNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:textColor="@color/text_primary" />
    </LinearLayout>
</ScrollView>
