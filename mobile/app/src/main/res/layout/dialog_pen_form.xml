<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pen Identifier"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/inputPenIdentifier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pen Name"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputPenName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Capacity"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputPenCapacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="number"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/inputPenDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_input"
            android:padding="12dp"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:textColor="@color/text_primary" />
    </LinearLayout>
</ScrollView>
